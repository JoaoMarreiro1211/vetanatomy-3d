# Frontend
NEXT_PUBLIC_API_BASE=https://YOUR_API_DOMAIN/api/v1

# VPS Docker Compose domains
WEB_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Backend
SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_URL=postgresql://user:password@host:5432/vetanatomy
BACKEND_CORS_ORIGINS=["https://YOUR_WEB_DOMAIN"]
ACCESS_TOKEN_EXPIRE_MINUTES=480

# VPS database values used by infra/docker/docker-compose.prod.yml
POSTGRES_USER=vetanatomy
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=vetanatomy

# Required for HTTPS production when API and web are on different domains
REFRESH_TOKEN_COOKIE_SECURE=True
REFRESH_TOKEN_COOKIE_SAMESITE=none
REFRESH_TOKEN_EXPIRE_DAYS=30
LOCAL_STORAGE_PATH=/app/storage
PUBLIC_STORAGE_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@vetanatomy.local
EMAIL_PROVIDER=smtp
SENDGRID_API_KEY=
